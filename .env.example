# Bitcoin Terminal Configuration
# Copy this file to .env and update with your settings

# Bitcoin Data Directory (auto-detected by scanner)
BITCOIN_DATADIR=

# Bitcoin RPC Configuration (optional - will try to read from bitcoin.conf)
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# Display Settings
REFRESH_INTERVAL=5
THEME=dark
